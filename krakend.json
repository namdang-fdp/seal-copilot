{
  "version": 3,
  "port": 8080,
  "timeout": "3000ms",
  "cache_ttl": "300s",
  "endpoints": [
    {
      "endpoint": "/api/v1/knowledge/global-sources",
      "method": "GET",
      "output_encoding": "json",
      "backend": [
        {
          "url_pattern": "/api/v1/global/sources",
          "method": "GET",
          "host": ["http://host.docker.internal:8000"]
        }
      ]
    },
    {
      "endpoint": "/api/v1/knowledge/contribute",
      "method": "POST",
      "output_encoding": "json",
      "backend": [
        {
          "url_pattern": "/api/v1/global/contribute",
          "method": "POST",
          "host": ["http://host.docker.internal:8000"]
        }
      ]
    }
  ]
}
